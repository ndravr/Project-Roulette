{
  "name": "project-roulette-desktop",
  "version": "0.4.0",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron .",
    "sync-version": "node scripts/sync-build-version.js",
    "prebuild": "node scripts/sync-build-version.js",
    "build": "electron-builder --win",
    "postbuild": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path dist/lists) { Remove-Item dist/lists -Recurse -Force }; Copy-Item lists dist/lists -Recurse\""
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "local.project-roulette.desktop",
    "productName": "Project Roulette",
    "files": [
      "index.html",
      "script.js",
      "styles.css",
      "fortune-cookie-messages.json",
      "cat.png",
      "cat.gif",
      "yarn.svg",
      "build/icon.ico",
      "project_roulette_font/**/*",
      "desktop/**/*"
    ],
    "extraFiles": [
      {
        "from": "lists",
        "to": "lists",
        "filter": [
          "**/*.txt"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "dir",
        "portable"
      ],
      "executableName": "Project-Roulette-0.4"
    },
    "portable": {
      "artifactName": "Project-Roulette-0.4.exe"
    },
    "compression": "store",
    "asar": true,
    "npmRebuild": false,
    "nodeGypRebuild": false
  }
}
